<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.carrental.mapper.NoticeMapper">

    <resultMap id="NoticeResultMap" type="com.carrental.entity.Notice">
        <id property="id" column="id"/>
        <result property="title" column="title"/>
        <result property="content" column="content"/>
        <result property="status" column="status"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
        <result property="deleted" column="deleted"/>
    </resultMap>

    <select id="selectNoticePage" resultMap="NoticeResultMap">
        SELECT * FROM notice
        WHERE deleted = 0
        <if test="title != null and title != ''">
            AND title LIKE CONCAT('%', #{title}, '%')
        </if>
        <if test="status != null">
            AND status = #{status}
        </if>
        ORDER BY create_time DESC
    </select>

    <select id="selectVisibleNotices" resultMap="NoticeResultMap">
        SELECT * FROM notice
        WHERE status = 1 AND deleted = 0
        ORDER BY create_time DESC
    </select>

</mapper>