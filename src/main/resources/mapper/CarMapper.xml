<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.carrental.mapper.CarMapper">

    <resultMap id="CarResultMap" type="com.carrental.entity.Car">
        <id property="id" column="id"/>
        <result property="carName" column="car_name"/>
        <result property="brand" column="brand"/>
        <result property="model" column="model"/>
        <result property="carNo" column="car_no"/>
        <result property="typeId" column="type_id"/>
        <result property="pricePerDay" column="price_per_day"/>
        <result property="seatNum" column="seat_num"/>
        <result property="image" column="image"/>
        <result property="status" column="status"/>
        <result property="description" column="description"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
        <result property="deleted" column="deleted"/>
        <result property="typeName" column="type_name"/>
    </resultMap>

    <select id="selectCarPage" resultMap="CarResultMap">
        SELECT c.*, ct.type_name
        FROM car c
        LEFT JOIN car_type ct ON c.type_id = ct.id
        WHERE c.deleted = 0 AND ct.deleted = 0
        <if test="keyword != null and keyword != ''">
            AND (c.car_name LIKE CONCAT('%', #{keyword}, '%')
                 OR c.brand LIKE CONCAT('%', #{keyword}, '%')
                 OR c.model LIKE CONCAT('%', #{keyword}, '%')
                 OR c.car_no LIKE CONCAT('%', #{keyword}, '%'))
        </if>
        <if test="typeId != null">
            AND c.type_id = #{typeId}
        </if>
        <if test="status != null">
            AND c.status = #{status}
        </if>
        ORDER BY c.create_time DESC
    </select>

    <select id="selectCarDetailById" resultMap="CarResultMap">
        SELECT c.*, ct.type_name
        FROM car c
        LEFT JOIN car_type ct ON c.type_id = ct.id
        WHERE c.id = #{id} AND c.deleted = 0 AND ct.deleted = 0
    </select>

    <select id="countActiveOrdersByCarId" resultType="java.lang.Integer">
        SELECT COUNT(*) FROM rent_order
        WHERE car_id = #{carId} 
          AND deleted = 0
          AND status IN (0, 1, 3)
    </select>

</mapper>